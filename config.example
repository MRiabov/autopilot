# BMAD Autopilot Configuration
# Copy this file to .autopilot/config in your target project
#
# All settings are optional - defaults are shown below
# Environment variables override these settings
# Command line flags (--debug) override environment variables

# Enable verbose console output (shows more details during execution)
# AUTOPILOT_VERBOSE=0

# Enable debug logging to .autopilot/tmp/debug.log (implies verbose)
# AUTOPILOT_DEBUG=0

# Flow mode:
#   auto   = story flow when sprint-status has story rows, otherwise legacy
#   story  = always use the story-first flow
#   legacy = keep the old epic/PR flow
# AUTOPILOT_FLOW=auto

# Legacy prompt budget kept for compatibility
# MAX_TURNS=80

# Seconds between QA or Copilot status polls
# CHECK_INTERVAL=30

# Maximum poll iterations before timeout
# MAX_CHECK_WAIT=60

# Maximum iterations waiting for Copilot review (defaults to MAX_CHECK_WAIT)
# MAX_COPILOT_WAIT=60

# Enable Gradle builds for mobile-native (requires Android toolchain)
# AUTOPILOT_RUN_MOBILE_NATIVE=0

# Override default branch detection (auto-detected from origin/HEAD, main, or master)
# AUTOPILOT_BASE_BRANCH=main

# =============================================================================
# EXECUTION MODE
# =============================================================================
# Story flow is the default. It follows the next story in sprint status and
# marks it done when review passes.
#
# Legacy epic/PR flow remains available when AUTOPILOT_FLOW=legacy.
#
# PARALLEL_MODE controls worktree usage in legacy flow:
#
#   0 = Sequential (default)
#       - One branch at a time on main worktree
#       - Simple, no extra worktrees needed
#
#   1+ = Parallel with worktrees
#       - Uses git worktrees for parallel branch management
#       - Value = max concurrent worktrees (e.g., PARALLEL_MODE=3)
#       - Useful when fixes needed on multiple PRs simultaneously
#
# PARALLEL_MODE=0

# Seconds between checking pending PRs status
# PARALLEL_CHECK_INTERVAL=60

# Maximum number of pending PRs before blocking new epic development
# MAX_PENDING_PRS=2
